<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="TaskFlowPU" transaction-type="JTA">
        <description>TaskFlow Persistence Unit</description>

        <!-- DataSource -->
        <jta-data-source>jdbc/TaskFlowDS</jta-data-source>

        <!-- Entities -->
        <class>il.openu.taskflow.entity.User</class>
        <class>il.openu.taskflow.entity.Project</class>
        <class>il.openu.taskflow.entity.Board</class>
        <class>il.openu.taskflow.entity.Task</class>
        <class>il.openu.taskflow.entity.Comment</class>
        <class>il.openu.taskflow.entity.ActivityLog</class>

        <properties>
            <!--><property name="jakarta.persistence.schema-generation.database.action" value="drop-and-create"/><!-->
            <property name="jakarta.persistence.schema-generation.database.action" value="none"/>
            <!--><property name="eclipselink.ddl-generation" value="drop-and-create-tables"/><!-->

            <property name="eclipselink.logging.level" value="INFO"/>
            <property name="eclipselink.logging.level.sql" value="WARNING"/>
        </properties>
    </persistence-unit>
</persistence>