<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE resources PUBLIC 
    "-//GlassFish.org//DTD GlassFish Application Server 3.1 Resource Definitions//EN" 
    "http://glassfish.org/dtds/glassfish-resources_1_5.dtd">

<resources>

    <!-- ================== JDBC (Application Scoped) ================== -->
    <jdbc-connection-pool 
        name="TaskFlowPool"
        res-type="javax.sql.DataSource"
        datasource-classname="org.mariadb.jdbc.MariaDbDataSource"
        max-pool-size="32"
        steady-pool-size="8">

        <property name="url" value="jdbc:mariadb://localhost:3306/taskflow_db"/>
        <property name="user" value="root"/>
        <property name="password" value="123456!"/>
    </jdbc-connection-pool>

    <jdbc-resource 
        enabled="true"
        jndi-name="java:app/jdbc/TaskFlowDS"
        object-type="user"
        pool-name="TaskFlowPool">
    </jdbc-resource>


    <!-- ================== JMS Queue (Application Scoped) ================== -->
    <admin-object-resource 
        enabled="true"
        jndi-name="java:app/jms/TaskEventsQueue"
        res-adapter="jmsra"
        res-type="jakarta.jms.Queue"
        object-type="user">

        <property name="Name" value="TaskEventsQueue"/>
    </admin-object-resource>

</resources>